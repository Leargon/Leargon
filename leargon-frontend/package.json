    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^7.3.9",
    "@tanstack/react-query": "^5.95.2",
    "@xyflow/react": "^12.10.2",
    "axios": "^1.13.6",
    "flatted": "^3.4.2",
    "i18next": "^25.10.10",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^17.0.0",
    "react-router-dom": "^7.13.2"
