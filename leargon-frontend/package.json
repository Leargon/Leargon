    "@xyflow/react": "^12.10.2",
    "axios": "^1.15.0",
    "flatted": "^3.4.2",
    "i18next": "^26.0.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-i18next": "^17.0.2",
