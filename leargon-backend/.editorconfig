root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

[*.{kt,kts}]
indent_size = 4
max_line_length = 140

# ktlint rules
ktlint_standard_trailing-comma-on-call-site = disabled
ktlint_standard_trailing-comma-on-declaration-site = disabled

[*.groovy]
indent_size = 4
max_line_length = 140

[*.{yaml,yml}]
indent_size = 2

[*.json]
indent_size = 2
