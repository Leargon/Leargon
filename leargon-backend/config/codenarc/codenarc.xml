<?xml version="1.0"?>
<ruleset xmlns="http://codenarc.org/ruleset/1.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://codenarc.org/ruleset/1.0 http://codenarc.org/ruleset-schema.xsd"
         xsi:noNamespaceSchemaLocation="http://codenarc.org/ruleset-schema.xsd">

    <description>CodeNarc ruleset for Leargon Spock tests</description>

    <!-- Basic code issues -->
    <ruleset-ref path="rulesets/basic.xml">
        <!-- Spock uses == for assertions, not equals() -->
        <exclude name="EqualsAndHashCode"/>
    </ruleset-ref>

    <!-- Imports -->
    <ruleset-ref path="rulesets/imports.xml">
        <exclude name="MissingBlankLineAfterImports"/>
        <exclude name="MissingBlankLineAfterPackage"/>
    </ruleset-ref>

    <!-- Naming: Spock method names are strings with spaces — skip MethodName.
         FactoryMethodName fires on every createXxx() helper in test specs. -->
    <ruleset-ref path="rulesets/naming.xml">
        <exclude name="MethodName"/>
        <exclude name="FactoryMethodName"/>
    </ruleset-ref>

    <!-- Unused variables and imports -->
    <ruleset-ref path="rulesets/unused.xml"/>

    <!-- Groovy-isms that can mask bugs.
         UnnecessaryGString: fires on every double-quoted string without interpolation
         (extremely common in Groovy/Spock); disable to avoid noise. -->
    <ruleset-ref path="rulesets/groovyism.xml">
        <exclude name="GStringExpressionWithinString"/>
        <exclude name="UnnecessaryReturnKeyword"/>
        <exclude name="UnnecessaryGString"/>
    </ruleset-ref>

    <!-- Design rules: skip ones that are too prescriptive for test code -->
    <ruleset-ref path="rulesets/design.xml">
        <exclude name="AbstractClassWithoutAbstractMethod"/>
        <exclude name="AbstractClassWithPublicConstructor"/>
        <exclude name="BuilderMethodWithSideEffects"/>
    </ruleset-ref>

    <!-- Unnecessary code -->
    <ruleset-ref path="rulesets/unnecessary.xml">
        <exclude name="UnnecessaryGetter"/>
        <exclude name="UnnecessarySetter"/>
        <exclude name="UnnecessaryReturnKeyword"/>
        <!-- UnnecessaryObjectReferences: requires complex refactoring for low gain in tests -->
        <exclude name="UnnecessaryObjectReferences"/>
        <!-- UnnecessaryGString: fires on every double-quoted string without interpolation
             (extremely common in Groovy/Spock); disable to avoid noise -->
        <exclude name="UnnecessaryGString"/>
    </ruleset-ref>

    <!-- Exception handling -->
    <ruleset-ref path="rulesets/exceptions.xml">
        <!-- Tests often catch Exception broadly -->
        <exclude name="CatchException"/>
        <exclude name="ThrowException"/>
    </ruleset-ref>

</ruleset>
